<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@drawable/widget_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginEnd="5dp" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CampConnectUs"
            android:textSize="12sp"
            android:textColor="#FF8C00"
            android:textStyle="bold" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tracking"
            android:textSize="9sp"
            android:textColor="#999999" />
    </LinearLayout>

    <!-- Two cards side by side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Latest Order card -->
        <LinearLayout
            android:id="@+id/widget_latest_order"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/widget_tracking_card_bg"
            android:padding="8dp"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/ic_menu_view"
                    android:tint="#FF8C00" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Latest Order"
                    android:textSize="9sp"
                    android:textColor="#666666"
                    android:layout_marginStart="3dp" />
            </LinearLayout>
            <TextView
                android:id="@+id/widget_order_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No orders yet"
                android:textSize="10sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:layout_marginTop="3dp" />
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="#E0E0E0"
                android:layout_marginTop="4dp">
                <View
                    android:id="@+id/widget_order_progress"
                    android:layout_width="20dp"
                    android:layout_height="4dp"
                    android:background="#FF8C00" />
            </FrameLayout>
            <TextView
                android:id="@+id/widget_order_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textColor="#FF8C00"
                android:textStyle="bold"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <!-- Refund card -->
        <LinearLayout
            android:id="@+id/widget_refund"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/widget_tracking_card_bg"
            android:padding="8dp"
            android:layout_marginStart="4dp"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:tint="#4CAF50" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Refund"
                    android:textSize="9sp"
                    android:textColor="#666666"
                    android:layout_marginStart="3dp" />
            </LinearLayout>
            <TextView
                android:id="@+id/widget_refund_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No refunds"
                android:textSize="10sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:layout_marginTop="3dp" />
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="#E0E0E0"
                android:layout_marginTop="4dp">
                <View
                    android:id="@+id/widget_refund_progress"
                    android:layout_width="0dp"
                    android:layout_height="4dp"
                    android:background="#4CAF50" />
            </FrameLayout>
            <TextView
                android:id="@+id/widget_refund_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:layout_marginTop="3dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
