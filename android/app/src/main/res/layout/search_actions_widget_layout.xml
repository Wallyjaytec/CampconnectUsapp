<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/widget_background">

    <!-- Header with bottom divider -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@drawable/widget_header_bg">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginEnd="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CampConnectUs"
            android:textSize="12sp"
            android:textColor="#FF8C00"
            android:textStyle="bold"
            android:layout_marginEnd="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="| Shop on CCU"
            android:textSize="11sp"
            android:textColor="#888888" />

    </LinearLayout>

    <!-- Content area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="10dp">

        <!-- Search bar -->
        <LinearLayout
            android:id="@+id/widget_search_bar"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:background="@drawable/widget_search_bg"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="10dp"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Search on CCU Marketplace..."
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:singleLine="true" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_camera"
                android:tint="#555555"
                android:layout_marginEnd="8dp" />

            <!-- Search icon in black circle like Temu -->
            <LinearLayout
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/widget_search_icon_bg"
                android:gravity="center">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_search"
                    android:tint="#FFFFFF" />
            </LinearLayout>

        </LinearLayout>

        <!-- 4 Quick action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Account -->
            <LinearLayout
                android:id="@+id/widget_account"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@drawable/widget_action_bg"
                android:layout_marginEnd="4dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:tint="#FF8C00" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Account"
                    android:textSize="9sp"
                    android:textColor="#333333"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <!-- Cart -->
            <LinearLayout
                android:id="@+id/widget_cart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@drawable/widget_action_bg"
                android:layout_marginEnd="4dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_shortcut_cart"
                    android:tint="#FF8C00" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cart"
                    android:textSize="9sp"
                    android:textColor="#333333"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <!-- Orders -->
            <LinearLayout
                android:id="@+id/widget_orders"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@drawable/widget_action_bg"
                android:layout_marginEnd="4dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_shortcut_orders"
                    android:tint="#FF8C00" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Orders"
                    android:textSize="9sp"
                    android:textColor="#333333"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <!-- Notifications -->
            <LinearLayout
                android:id="@+id/widget_notifications"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@drawable/widget_action_bg">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_popup_reminder"
                    android:tint="#FF8C00" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notif"
                    android:textSize="9sp"
                    android:textColor="#333333"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
