<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/widget_background">

    <!-- Orange header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@drawable/widget_header_bg">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/search_widget_logo"
            android:scaleType="centerCrop"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CampConnectUs"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="| Shop with us on CCU"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:alpha="0.8" />

    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp">

        <!-- Search bar -->
        <LinearLayout
            android:id="@+id/widget_search_bar"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@drawable/widget_search_bg"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="6dp"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="7dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Search on CampConnectUs Marketplace..."
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:singleLine="true" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_camera"
                android:tint="#1A1A1A"
                android:layout_marginEnd="6dp" />

            <LinearLayout
                android:layout_width="34dp"
                android:layout_height="26dp"
                android:background="@drawable/widget_search_icon_bg"
                android:gravity="center">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_search"
                    android:tint="#FFFFFF" />
            </LinearLayout>

        </LinearLayout>

        <!-- 4 action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/widget_account"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="7dp"
                android:paddingBottom="7dp"
                android:background="@drawable/widget_action_bg"
                android:layout_marginEnd="4dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/widget_icon_account" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Account"
                    android:textSize="9sp"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_cart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="7dp"
                android:paddingBottom="7dp"
                android:background="@drawable/widget_action_bg"
                android:layout_marginEnd="4dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/widget_icon_cart" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cart"
                    android:textSize="9sp"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_orders"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="7dp"
                android:paddingBottom="7dp"
                android:background="@drawable/widget_action_bg"
                android:layout_marginEnd="4dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/widget_icon_orders" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Orders"
                    android:textSize="9sp"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_notifications"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="7dp"
                android:paddingBottom="7dp"
                android:background="@drawable/widget_action_bg">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/widget_icon_notif" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notif"
                    android:textSize="9sp"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
